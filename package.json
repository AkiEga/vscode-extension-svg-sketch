{
  "name": "svg-sketch",
  "displayName": "SVG Sketch",
  "description": "Canvas-based SVG diagram editor for creating and editing .svg files in VS Code",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AkiEga/vscode-extension-svg-sketch.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "bin": {
    "svg-sketch-cli": "./out/svg-sketch-cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "svg-sketch.newDiagram",
        "title": "SVG Sketch: New SVG"
      },
      {
        "command": "svg-sketch.editSvg",
        "title": "SVG Sketch: Edit SVG"
      },
      {
        "command": "svg-sketch.createSvgFile",
        "title": "SVG Sketch: Create SVG File"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "svg-sketch.newDiagram",
          "group": "svgSketch@1"
        },
        {
          "command": "svg-sketch.editSvg",
          "when": "resourceExtname == .svg",
          "group": "svgSketch@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "svg-sketch.editSvg",
          "when": "resourceExtname == .svg",
          "group": "svgSketch@1"
        }
      ]
    },
    "configuration": {
      "title": "SVG Sketch",
      "properties": {
        "svg-sketch.shapeDefaultsSvgPath": {
          "type": "string",
          "default": "",
          "description": "Path to a custom SVG file that defines default shape styles. Leave empty to use the built-in defaults. The SVG must follow the same format as the bundled shapeDefaults.svg."
        },
        "svg-sketch.svgOutputDir": {
          "type": "string",
          "default": "images",
          "description": "Directory to save SVG files when using the 'Create SVG File' command (relative to workspace root or current file directory)."
        },
        "svg-sketch.templateDir": {
          "type": "string",
          "default": "",
          "description": "Directory to store diagram templates (relative to workspace root). Leave empty to disable template features."
        },
        "svg-sketch.defaultStroke": {
          "type": "string",
          "default": "#000000",
          "description": "Default stroke color for newly created shapes (hex color)."
        },
        "svg-sketch.defaultFill": {
          "type": "string",
          "default": "#ffffff",
          "description": "Default fill color for newly created shapes (hex color)."
        },
        "svg-sketch.defaultLineWidth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 20,
          "description": "Default line width for newly created shapes."
        },
        "svg-sketch.screenshotPasteEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable pasting screenshots/images from clipboard into the canvas."
        },
        "svg-sketch.screenshotPasteMaxWidth": {
          "type": "number",
          "default": 1024,
          "minimum": 128,
          "maximum": 4096,
          "description": "Maximum width of pasted screenshots in pixels."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "svgSketch.svgEditor",
        "displayName": "SVG Sketch Editor",
        "selector": [
          {
            "filenamePattern": "*.svg"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src/ webview/ --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node out/svg-sketch-cli.js",
    "serve": "node out/svg-sketch-cli.js serve",
    "test:e2e": "npx playwright test",
    "package:vsix": "npm run build && npx @vscode/vsce package --out release/"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
