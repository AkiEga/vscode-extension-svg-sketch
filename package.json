{
  "name": "ascii-sketch",
  "displayName": "ASCII Sketch",
  "description": "Canvas-based ASCII art editor that embeds diagrams into Markdown code blocks in VS Code",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AkiEga/vscode-extension-svg-sketch.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ascii-sketch.newDiagram",
        "title": "ASCII Sketch: New Diagram"
      },
      {
        "command": "ascii-sketch.editDiagram",
        "title": "ASCII Sketch: Edit Diagram At Cursor"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ascii-sketch.newDiagram",
          "when": "editorLangId == markdown",
          "group": "asciiSketch@1"
        },
        {
          "command": "ascii-sketch.editDiagram",
          "when": "editorLangId == markdown",
          "group": "asciiSketch@2"
        }
      ]
    },
    "configuration": {
      "title": "ASCII Sketch",
      "properties": {
        "ascii-sketch.defaultWidth": {
          "type": "number",
          "default": 80,
          "minimum": 20,
          "maximum": 400,
          "description": "Initial width of the ASCII art editor grid. The buffer expands dynamically when needed."
        },
        "ascii-sketch.defaultHeight": {
          "type": "number",
          "default": 20,
          "minimum": 5,
          "maximum": 200,
          "description": "Initial height of the ASCII art editor grid. The buffer expands dynamically when needed."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src/ webview/ --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:vsix": "npm run build && npx @vscode/vsce package --out release/"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
