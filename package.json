{
  "name": "svg-sketch",
  "displayName": "SVG Sketch",
  "description": "Canvas-based SVG diagram editor for creating and editing .svg files in VS Code",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svg-sketch.newDiagram",
        "title": "SVG Sketch: New SVG"
      }
    ],
    "configuration": {
      "title": "SVG Sketch",
      "properties": {
        "svg-sketch.templateDir": {
          "type": "string",
          "default": ".svg-sketch/templates",
          "description": "Directory to store diagram templates (relative to workspace root)"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "svgSketch.svgEditor",
        "displayName": "SVG Sketch Editor",
        "selector": [
          {
            "filenamePattern": "*.svg"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src/ webview/ --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
