{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "outDir": "out",
    "rootDir": "..",
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "./**/*.ts",
    "../webview/**/*.ts",
    "../src/types.ts",
    "../src/svgExporter.ts",
    "../src/shapeConfig.ts"
  ]
}
