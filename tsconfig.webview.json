{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "outDir": "out-webview",
    "lib": ["ES2022", "DOM"],
    "sourceMap": true,
    "rootDir": "webview",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": ["webview/**/*.ts"],
  "exclude": ["node_modules"]
}
